            android:pathData="M33.6,97.8m-4.1,0a4.1,3.3 0,1 1,8.2 0a4.1,3.3 0,1 1,-8.2 0" />
        <path android:fillColor="#3A4560"
            android:pathData="M37,95.4m-1.6,0a1.6,1.4 0,1 1,3.2 0a1.6,1.4 0,1 1,-3.2 0" />
        <!-- tripod: three splayed legs, centre one shorter for perspective -->
        <path android:strokeColor="#2A3348" android:strokeWidth="2.3"
            android:strokeLineCap="round" android:pathData="M46.8,92.6L38.6,101.5" />
        <path android:strokeColor="#2A3348" android:strokeWidth="2.3"
            android:strokeLineCap="round" android:pathData="M46.8,92.6L55.4,101.5" />
        <path android:strokeColor="#2A3348" android:strokeWidth="2.1"
            android:strokeLineCap="round" android:pathData="M46.8,92.6L47.4,99.4" />
        <path android:strokeColor="#2A3348" android:strokeWidth="1.3"
            android:strokeAlpha="0.9" android:pathData="M42.6,97h8.4" />
    </group>
</vector>
