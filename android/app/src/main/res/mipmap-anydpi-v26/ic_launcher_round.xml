<?xml version="1.0" encoding="utf-8"?>
<!--
    Round variant, for launchers that request android:roundIcon explicitly.
    Deliberately identical to ic_launcher: the adaptive layers are already
    mask-agnostic, and the composition was checked under a circular crop —
    the sky and ground bleed to the edges, while the telescope and all three
    targets sit inside the 72x72 safe zone.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
